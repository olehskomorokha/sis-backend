  {
    "ChannelId": "UC1YCuQvQrPbNaJ6UnX4xyJQ",
    "Title": "\u0420\u0438\u0431\u043E\u043B\u043E\u0432\u043B\u044F \u0432 \u0423\u043A\u0440\u0430\u0457\u043D\u0456",
    "Description": "\u0412\u0456\u0442\u0430\u044E \u0443\u0441\u0456\u0445 \u043D\u0430 \u043C\u043E\u0454\u043C\u0443 \u043A\u0430\u043D\u0430\u043B\u0456 \u0440\u0438\u0431\u043E\u043B\u043E\u0432\u043B\u044F \u0432 \u0423\u043A\u0440\u0430\u0457\u043D\u0456   , \u0440\u0438\u0431\u043E\u043B\u043E\u0432\u043B\u044F \u0444\u0456\u0434\u0435\u0440\u043E\u043C \u043D\u0430 \u0420\u0456\u0447\u0446\u0456 , \u043D\u0430 \u041E\u0437\u0435\u0440\u0456 , \u0442\u0430 \u0443 \u043B\u044E\u0431\u0456\u0439 \u0432\u043E\u0434\u043E\u0439\u043C\u0456 , \u0440\u0438\u0431\u043E\u043B\u043E\u0432\u043B\u044F \u0432 \u0423\u043A\u0440\u0430\u0457\u043D\u0456 \u043F\u043E \u043E\u0431\u043B\u0430\u0441\u0442\u044F\u043C \u0442\u0430 \u0440\u0430\u0439\u043E\u043D\u0430\u043C , \u0440\u0438\u0431\u0430\u043B\u0438\u043C \u043F\u043E \u0431\u043B\u0438\u0437\u0443 \u043C\u0456\u0441\u0442\u0430 \u043D\u0430 \u0440\u0456\u0437\u043D\u0456 \u0432\u0438\u0434\u0438 \u0440\u0438\u0431 \u044F\u043A , \u0449\u0443\u043A\u0430 , \u0441\u043E\u043C , \u043A\u043E\u0440\u043E\u043F , \u043B\u044F\u0449 , \u043B\u0438\u043D\u043E\u043A ,\u043A\u0430\u0440\u0430\u0441\u044C , \u043F\u043B\u043E\u0442\u0432\u0430 , \u043E\u043A\u0443\u043D\u044C , \u0433\u0443\u0441\u0442\u0435\u0440\u0430 ,\u0441\u0443\u0434\u0430\u043A , \u0436\u0435\u0440\u0435\u0445 , \u0433\u043E\u043B\u0430\u0432\u043B\u044C , \u043D\u0430\u043B\u0438\u043C , \u0442\u0430 \u0449\u0435 \u0431\u0430\u0433\u0430\u0442\u043E \u0456\u043D\u0448\u0438\u0445 \u0432\u0438\u0434\u0456\u0432 \u0440\u0438\u0431 \u0430 \u043E\u0441\u043E\u0431\u043B\u0438\u0432\u043E \u043B\u044E\u0431\u043B\u044E \u043B\u043E\u0432\u0438\u0442\u0438 \u043D\u0430 \u043A\u0440\u0443\u0436\u043A\u0438 , \u0449\u0443\u043A\u0443 , \u0436\u0435\u0440\u0435\u0445\u0430  . \u0422\u0430\u043A\u043E\u0436 \u043F\u043E\u043B\u044E\u0431\u043B\u044F\u044E \u0440\u0438\u0431\u0430\u043B\u0438\u0442\u0438 \u0437\u0438\u043C\u043E\u044E \u0437 \u043B\u044C\u043E\u0434\u0443 \u043D\u0430 \u043C\u0430\u0440\u043C\u0438\u0448\u043A\u0443 \u0442\u0430 \u0436\u0435\u0440\u043B\u0438\u0446\u0456  . \u041C\u043E\u0436\u0443 \u0441\u043A\u0430\u0437\u0430\u0442\u0438 \u0432\u043F\u0435\u0432\u043D\u0435\u043D\u043E \u0449\u043E \u0440\u0438\u0431\u0430\u043B\u043A\u0430 \u0437\u0430\u0439\u043C\u0430\u0454 \u0443 \u043C\u0435\u043D\u0435 \u0431\u0430\u0433\u0430\u0442\u043E \u0447\u0430\u0441\u0443 \u0442\u0430 \u0437\u0443\u0441\u0438\u043B\u044C . \u042F \u0441\u0442\u0430\u0440\u0430\u044E\u0441\u044C \u0457\u0437\u0434\u0438\u0442\u0438 \u043D\u0430 \u0440\u0438\u0431\u0430\u043B\u043A\u0443 \u0432 \u043D\u0430\u0439\u043A\u0440\u0430\u0449\u0456 \u043C\u0456\u0441\u044C\u0446\u044F \u0449\u043E\u0431 \u0432\u0438 \u0437\u043C\u043E\u0433\u043B\u0438 \u043F\u043E\u0431\u0430\u0447\u0438\u0442\u0438 \u0449\u043E\u0441\u044C \u0446\u0456\u043A\u0430\u0432\u0435 \u0442\u0430 \u043D\u043E\u0432\u0435 \u0442\u0430 \u0449\u043E\u0431 \u0437\u043C\u043E\u0433\u043B\u0438 \u0437\u043D\u0430\u0439\u0442\u0438 \u0434\u043B\u044F \u0441\u0435\u0431\u0435 \u043D\u043E\u0432\u0456 \u043C\u0456\u0441\u0446\u044F \u0434\u043B\u044F \u0440\u0438\u0431\u0430\u043B\u043A\u0456 \u0442\u0430 \u0432\u0456\u0434\u043F\u043E\u0447\u0438\u043D\u043A\u0443 , \u0430 \u0442\u0430\u043A\u043E\u0436 \u0433\u043E\u0442\u0443\u0454\u043C \u043D\u0430 \u043F\u0440\u0438\u0440\u043E\u0434\u0456 \u0440\u0456\u0437\u043D\u0456 \u0440\u0438\u0431\u043D\u0456 \u0441\u0442\u0440\u0430\u0432\u0438 \u0442\u0430\u043A\u0456 \u044F\u043A \u0448\u0430\u0448\u043B\u0438\u043A , \u0443\u0445\u0430 , \u0437\u0430\u043F\u0435\u0447\u0435\u043D\u0430 \u0440\u0438\u0431\u0430 ,\u0436\u0430\u0440\u0435\u043D\u0430 \u0440\u0438\u0431\u0430 \u0456 \u0449\u0435 \u0431\u0430\u0433\u0430\u0442\u043E \u0440\u0456\u0437\u043D\u0438\u0445 \u0432\u043A\u0443\u0441\u043D\u044F\u0448\u043E\u043A .\u0422\u0430\u043A\u043E\u0436 \u0457\u0437\u0434\u0438\u043C \u043D\u0430 \u043D\u0456\u0447\u043D\u0443 \u0440\u0438\u0431\u043E\u043B\u043E\u0432\u043B\u044E \u043D\u0430 \u0441\u043E\u043C\u0430  .  \u0414\u0440\u0443\u0437\u0456 \u043F\u0456\u0434\u043F\u0438\u0441\u0443\u0439\u0442\u0435\u0441\u044C \u043D\u0430 \u043A\u0430\u043D\u0430\u043B \u043D\u0430\u0442\u0438\u0441\u043A\u0430\u0439\u0442\u0435 \u043D\u0430 \u0434\u0437\u0432\u0456\u043D\u043E\u0447\u043E\u043A \u0442\u0430 \u0441\u0442\u0430\u0432\u0442\u0435 \u043B\u0430\u0439\u043A\u0456 \u0443\u0441\u0456\u043C \u0432\u0430\u043C \u044F \u0434\u044F\u043A\u043E\u044E \u0437\u0430 \u0432\u0430\u0448\u0443 \u0443\u0432\u0430\u0433\u0443 .\n                                         \n",
