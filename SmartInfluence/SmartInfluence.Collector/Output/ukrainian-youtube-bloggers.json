    "Title": "\u0422\u0435\u043B\u0435\u043A\u0430\u043D\u0430\u043B \u0022\u0420\u0438\u0431\u0430\u043B\u043A\u0430\u0022",
    "Description": "\u0422\u0435\u043B\u0435\u043A\u0430\u043D\u0430\u043B \u0022\u0420\u0438\u0431\u0430\u043B\u043A\u0430\u0022 \u0432\u0436\u0435 \u0446\u0456\u0454\u0457 \u043E\u0441\u0435\u043D\u0456 \u0443 \u0432\u0441\u0456\u0445 \u043A\u0430\u0431\u0435\u043B\u044C\u043D\u0438\u0445 \u043C\u0435\u0440\u0435\u0436\u0430\u0445 \u0423\u043A\u0440\u0430\u0457\u043D\u0438! \n\u041F\u0435\u0440\u0448\u0438\u0439 \u0443\u043A\u0440\u0430\u0457\u043D\u0441\u044C\u043A\u0438\u0439 \u0440\u043E\u0437\u0432\u0430\u0436\u0430\u043B\u044C\u043D\u0438\u0439 \u0442\u0435\u043B\u0435\u043A\u0430\u043D\u0430\u043B \u043F\u0440\u043E \u0440\u0438\u0431\u0430\u043B\u043A\u0443 \u043F\u043E-\u043D\u043E\u0432\u043E\u043C\u0443.\n\n\u041D\u043E\u0432\u0456 \u0432\u0440\u0430\u0436\u0435\u043D\u043D\u044F \u0432\u0456\u0434 \u0443\u043B\u044E\u0431\u043B\u0435\u043D\u043E\u0433\u043E \u0437\u0430\u043D\u044F\u0442\u0442\u044F: \u043A\u0440\u0430\u0449\u0456 \u0440\u0438\u0431\u043E\u043B\u043E\u0432\u043D\u0456 \u0441\u043F\u043E\u0442\u0438 \u043C\u0435\u0433\u0430\u043F\u043E\u043B\u0456\u0441\u0456\u0432, \u0440\u0438\u0431\u043D\u0456 \u043C\u0456\u0441\u0446\u044F \u0423\u043A\u0440\u0430\u0457\u043D\u0438, \u0442\u0430\u0454\u043C\u043D\u0456 \u043B\u0430\u0439\u0444-\u0445\u0430\u043A\u0438 \u0432\u0456\u0434\u043E\u043C\u0438\u0445 \u0440\u0438\u0431\u0430\u043B\u043E\u043A, \u0435\u043A\u0441\u043A\u043B\u044E\u0437\u0438\u0432\u043D\u0456 \u0440\u0435\u043F\u043E\u0440\u0442\u0430\u0436\u0456 \u0437 \u043D\u0430\u0439\u0431\u0456\u043B\u044C\u0448\u0438\u0445 \u0437\u043C\u0430\u0433\u0430\u043D\u044C \u0423\u043A\u0440\u0430\u0457\u043D\u0438 \u0456 \u0441\u0432\u0456\u0442\u0443, \u0456\u043D\u0442\u0435\u0440\u0432\u0027\u044E \u0437 \u043F\u0440\u043E\u0444\u0435\u0441\u0456\u043E\u043D\u0430\u043B\u0430\u043C\u0438 \u0440\u0438\u0431\u0430\u043B\u043A\u0438 \u0442\u0430 \u0432\u0456\u0434\u043E\u043C\u0438\u043C\u0438 \u0440\u0438\u0431\u0430\u043A\u0430\u043C\u0438-\u043B\u044E\u0431\u0438\u0442\u0435\u043B\u044F\u043C\u0438, \u0441\u0442\u0430\u0440\u0456 \u0437\u0430\u0431\u0443\u0442\u0456 \u0445\u0438\u0442\u0440\u043E\u0449\u0456 \u0434\u043B\u044F \u0441\u0443\u0447\u0430\u0441\u043D\u043E\u0433\u043E \u0440\u0438\u0431\u043D\u043E\u0433\u043E \u043F\u043E\u043B\u044E\u0432\u0430\u043D\u043D\u044F \u0442\u0430 \u0440\u0438\u0431\u043D\u0430 \u043A\u0443\u0445\u043D\u044F. \n\u0417\u043B\u043E\u0432\u0438\u043C\u043E \u0440\u0438\u0431\u0443 \u0442\u0432\u043E\u0454\u0457 \u043C\u0440\u0456\u0457 \u0440\u0430\u0437\u043E\u043C!\n\n\u041F\u0456\u0434\u043F\u0438\u0448\u0438\u0441\u044C \u043D\u0430 \u043E\u0444\u0456\u0446\u0456\u0439\u043D\u0438\u0439 Youtube-\u043A\u0430\u043D\u0430\u043B \u0422\u0435\u043B\u0435\u043A\u0430\u043D\u0430\u043B\u0443 \u0022\u0420\u0438\u0431\u0430\u043B\u043A\u0430\u0022 - \u0442\u0432\u043E\u044F \u0440\u0438\u0431\u0430\u043B\u043A\u0430 24/7 - \u0432\u0435\u0441\u0435\u043B\u043E, \u0446\u0456\u043A\u0430\u0432\u043E, \u0441\u043C\u0430\u0447\u043D\u043E!",
